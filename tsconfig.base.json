{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": false,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "noEmit": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@repostitch/core": ["packages/core/src/index.ts"],
      "@repostitch/github": ["packages/github/src/index.ts"],
      "@repostitch/judge": ["packages/judge/src/index.ts"],
      "@repostitch/pack": ["packages/pack/src/index.ts"]
    }
  }
}

